#!/bin/sh
# Strips Cursor "Made with" / co-authored trailers from COMMIT_EDITMSG.
# Also turn off IDE attribution: Cursor Settings → Agents → Attribution → Commit attribution.
case "$2" in merge|squash) exit 0 ;; esac
test -f "$1" || exit 0
exec python3 "$(dirname "$0")/strip_cursor_trailers.py" "$1"
